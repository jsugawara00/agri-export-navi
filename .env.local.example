# 運用コンソール /ops の表示フラグ（運用者の手元専用。本番Vercelには設定しない。
# 未設定だと /ops は404になる）
OPS_CONSOLE=1

# Firebase設定（Phase 2: 案件のクラウド保存＋Googleログイン）
# Firebaseコンソール > プロジェクトの設定 > 全般 > マイアプリ から取得し、
# このファイルを .env.local にコピーして値を埋める。
# 未設定でもアプリは動作する（案件はブラウザのローカル保存モードになる）。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
